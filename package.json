{
  "name": "vpn-subscription-automation",
  "version": "0.2.0",
  "description": "AutoVPN Electron desktop app for VPN subscription automation",
  "author": "SwimmingLiu",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "electron:dev": "electron .",
    "test:electron": "node --test electron/tests/*.test.mjs",
    "test:all": "./scripts/run_pytest.sh tests -v && node --test electron/tests/*.test.mjs",
    "package:electron": "node electron/build/package.mjs"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "playwright": "^1.55.0"
  },
  "build": {
    "appId": "com.swimmingliu.vpnautomation",
    "productName": "AutoVPN",
    "files": [
      "electron/**/*",
      "src/**/*",
      "templates/**/*",
      "pyproject.toml"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "electron/build/assets/app-icon.icns"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
