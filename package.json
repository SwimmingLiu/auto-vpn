{
  "name": "vpn-subscription-automation",
  "version": "1.7.0",
  "description": "AutoVPN Electron desktop app for VPN subscription automation",
  "homepage": "https://github.com/SwimmingLiu/auto-vpn#readme",
  "author": {
    "name": "SwimmingLiu",
    "email": "swimmingliu@users.noreply.github.com"
  },
  "license": "AGPL-3.0-only",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "build:autovpn-cli": "npm run build --prefix npm/autovpn-cli",
    "preelectron:dev": "npm run build:autovpn-cli",
    "electron:dev": "electron .",
    "pretest:h5": "npm run build:autovpn-cli",
    "test:h5": "node --test --test-concurrency=1 electron/tests/mobile-layout-contract.test.mjs electron/tests/web-server-e2e.test.mjs electron/tests/web-server-visual.test.mjs",
    "pretest:electron-native": "npm run build:autovpn-cli",
    "test:electron-native": "node --test --test-concurrency=1 electron/tests/app-launch.test.mjs electron/tests/artifact-preview.test.mjs electron/tests/backend.test.mjs electron/tests/ci-retry-helper.test.mjs electron/tests/package-build.test.mjs electron/tests/pipeline-child-finalizer.test.mjs electron/tests/process-lifecycle.test.mjs electron/tests/release-docs-workflow.test.mjs electron/tests/release-notes.test.mjs electron/tests/renderer-e2e.test.mjs electron/tests/renderer-visual.test.mjs electron/tests/ui-state.test.mjs electron/tests/window-config.test.mjs",
    "pretest:electron": "npm run build:autovpn-cli",
    "test:electron": "npm run test:h5 && npm run test:electron-native",
    "test:all": "npm test --prefix npm/autovpn-cli && npm run test:electron",
    "package:electron": "node electron/build/package.mjs"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "26.8.1",
    "js-yaml": "4.3.0"
  },
  "build": {
    "appId": "com.swimmingliu.vpnautomation",
    "productName": "AutoVPN",
    "files": [
      "electron/**/*",
      "!electron/tests/**/*",
      "templates/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "electron/build/assets/app-icon.icns"
    },
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "maintainer": "SwimmingLiu <swimmingliu@users.noreply.github.com>",
      "icon": "electron/build/assets/app-icon-1024.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/build/assets/app-icon.ico"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "writeUpdateInfo": false
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "differentialPackage": false,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "playwright": "1.59.1",
    "qrcode": "1.5.4"
  }
}
