{
  "name": "vpn-subscription-automation",
  "version": "1.6.0",
  "description": "AutoVPN Electron desktop app for VPN subscription automation",
  "homepage": "https://github.com/SwimmingLiu/auto-vpn#readme",
  "author": {
    "name": "SwimmingLiu",
    "email": "swimmingliu@users.noreply.github.com"
  },
  "license": "AGPL-3.0-only",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "electron:dev": "electron .",
    "test:electron": "node --test --test-concurrency=1 electron/tests/*.test.mjs",
    "test:all": "./scripts/run_pytest.sh tests -v && npm run test:electron",
    "package:electron": "node electron/build/package.mjs"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.swimmingliu.vpnautomation",
    "productName": "AutoVPN",
    "files": [
      "electron/**/*",
      "!electron/tests/**/*",
      "src/**/*",
      "templates/**/*",
      "pyproject.toml"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "electron/build/assets/app-icon.icns"
    },
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "maintainer": "SwimmingLiu <swimmingliu@users.noreply.github.com>",
      "icon": "electron/build/assets/app-icon-1024.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/build/assets/app-icon.ico"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "writeUpdateInfo": false
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "differentialPackage": false,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "qrcode": "^1.5.4"
  }
}
